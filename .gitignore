/build/
/out/
cmake-build-*/

# Installer kimenet (a lefordított Setup.exe-t nem verziózzuk; az .iss igen)
/installer/Output/

# IDE
.vs/
.vscode/
.idea/
*.user

# OS
Thumbs.db
.DS_Store

# ASIO SDK: a Steinberg ASIO SDK GPLv3 variánsa VERZIÓKÖVETHETŐ (a build
# fordítási idejű függősége) — ezért már NEM ignoráljuk az egészet.
# KIVÉTEL: a Steinberg ASIO logó-artwork VÉDJEGY, NEM a GPL fedi → ezt nem
# verziózzuk (és a terméken sem használjuk).
/ext/ASIOSDK/Steinberg ASIO Logo Artwork/

# A modelleket NEM verziókövetjük (nagy bináris fájlok + a kereskedelmi
# NAM-captúrák licence). Lokálisan a build így is használja őket a
# GUITARDSP_DEFAULT_MODELS_DIR útvonalon keresztül.
/models/
