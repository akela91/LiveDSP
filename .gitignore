# Build outputs
/build/
/out/
cmake-build-*/

# Installer output (the compiled Setup.exe is not versioned; the .iss is)
/installer/Output/

# IDE
.vs/
.vscode/
.idea/
*.user

# OS
Thumbs.db
.DS_Store

# ASIO SDK: the Steinberg ASIO SDK GPLv3 variant IS version-controlled (it is a
# build-time dependency), so we no longer ignore the whole folder.
# EXCEPTION: the Steinberg ASIO logo artwork is a TRADEMARK, not covered by the
# GPL -> we do not version it (and do not use it in the product).
/ext/ASIOSDK/Steinberg ASIO Logo Artwork/

# Models and presets are NOT version-controlled or shipped: the commercial NAM
# captures cannot be redistributed. End users get a writable
# <Documents>/LiveDSP/{models,favs} folder; for development the build still uses
# any local folders here via LIVEDSP_DEFAULT_MODELS_DIR / LIVEDSP_FAVS_DIR.
/models/
/favs/
